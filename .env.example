# 이 파일을 .env로 복사하고 값을 채워 넣으세요.
# .env 파일은 .gitignore에 포함되어 있어 커밋되지 않습니다.

# ── 데이터 다운로드 (앱 실행에만 사용, 선택) ──
# HuggingFace에 업로드된 판례 DB의 위치.
# 비워두면 app.py의 기본값(공식 리포)을 사용합니다.
# 포크해서 자신의 HF 리포를 쓰고 싶을 때만 값을 넣으세요.
PRECEDENTS_HF_REPO=
PRECEDENTS_HF_FILE=

# ── 판례/법령 수집 (파이프라인 재실행 시만 필요) ──
# 국가법령정보센터 OpenAPI 접속 ID.
# 신청: https://open.law.go.kr/LSO/openApi/guideList.do
# 일반 사용자는 설정할 필요 없습니다. 사전 수집된 HuggingFace 데이터로 충분합니다.
LAW_GO_KR_OC=

# ── 쉬운 설명 AI 생성 (선택, 현재 미사용) ──
# Anthropic Claude API 키. scripts/generate_explanations.py 실행 시에만 필요.
ANTHROPIC_API_KEY=
